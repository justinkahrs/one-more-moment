---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import TechMarquee from "../components/TechMarquee.astro";
import FAQ from "../components/FAQ.astro";
---

<Base overlayHeader={true}>
  <Hero />
  <section class="bg-[#FFFBF6] px-4 py-14 md:py-16">
    <div
      class="mx-auto flex max-w-5xl flex-col items-start gap-6 rounded-2xl border border-[#E5DACE] bg-white/80 p-6 shadow-sm md:flex-row md:items-center md:justify-between md:p-8"
    >
      <div class="max-w-3xl">
        <h2 class="mb-3 text-2xl font-bold text-[#2B2B40] md:text-3xl">
          Looking for wish granting for adults with cancer in Michigan?
        </h2>
        <p class="leading-relaxed text-[#4A4A4A]">
          One More Moment helps adults facing Stage IV, advanced, or metastatic
          cancer create meaningful Moments with loved ones. Learn who we help,
          what a Moment can look like, and how families, friends, oncology
          teams, hospice workers, and social workers can start a request.
        </p>
      </div>
      <a
        href="/adult-cancer-wishes-michigan/"
        class="btn shrink-0 rounded-md border-0 bg-[#D9776E] px-6 text-white shadow-sm hover:bg-[#c5665d]"
      >
        Learn About Adult Cancer Wishes in Michigan
      </a>
    </div>
  </section>
  <Services />
  <TechMarquee />
  <FAQ />
</Base>

---
import Base from "../layouts/Base.astro";

const pageTitle = "Volunteer With One More Moment | Michigan Cancer Nonprofit";
const pageDescription =
  "Volunteer with One More Moment and help create meaningful experiences for adults in Michigan facing late-stage cancer.";
---

<Base title={pageTitle} description={pageDescription}>
  <div class="container mx-auto max-w-4xl px-4 py-12">
    <div class="mb-14 text-center">
      <h1 class="mb-6 font-serif text-5xl text-[#2B2B40] md:text-6xl">
        Volunteer With One More Moment
      </h1>
      <p class="mx-auto max-w-2xl text-lg opacity-80">
        We are grateful for people who want to help create meaningful moments
        for adults facing late-stage cancer and the people who love them. Share
        your contact information and a little about how you would like to help,
        and our team will follow up.
      </p>
    </div>

    {/* Get Involved Form */}
    <section class="mx-auto max-w-2xl">
      <h2 class="mb-8 font-serif text-4xl">Get Involved</h2>
      <form id="volunteer-request-form" class="flex flex-col gap-6">
        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Name</span>
          </label>
          <input
            type="text"
            name="name"
            placeholder="Your Name"
            class="input input-bordered w-full rounded-md focus:outline-offset-0 text-gray-400"
            required
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Email</span>
          </label>
          <input
            type="email"
            name="email"
            placeholder="Your Email"
            class="input input-bordered w-full rounded-md focus:outline-offset-0 text-gray-400"
            required
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">How can you help?</span>
          </label>
          <textarea
            name="help"
            class="textarea textarea-bordered h-32 w-full rounded-md focus:outline-offset-0 text-gray-400"
            placeholder="Tell us about your skills and interests"></textarea>
        </div>

        <div class="mt-4">
          <button
            type="submit"
            class="btn min-w-[120px] rounded-md bg-[#D9776E] px-8 text-white hover:bg-[#c5665d]"
          >
            Submit
          </button>
        </div>
      </form>
    </section>
  </div>
</Base>

<script>
  const form = document.getElementById(
    "volunteer-request-form",
  ) as HTMLFormElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    if (!submitBtn) return;

    const originalText = submitBtn.innerText;
    submitBtn.innerText = "Submitting...";
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/submit-volunteer", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        alert("Thank you for volunteering! We will be in touch soon.");
        form.reset();
      } else {
        alert(
          result.message || "Something went wrong. Please try again later.",
        );
      }
    } catch (error) {
      console.error("Error:", error);
      alert("An error occurred. Please try again.");
    } finally {
      submitBtn.innerText = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

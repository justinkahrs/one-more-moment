---
import FadeIn from "../components/FadeIn.astro";
import Layout from "../layouts/Base.astro";
import { frontmatter as metadata } from "../data/metadata.mdx";

// Fetch products from Fourthwall Storefront API
const STOREFRONT_TOKEN = import.meta.env.FOURTHWALL_STOREFRONT_TOKEN;
const STOREFRONT_URL = "https://storefront-api.fourthwall.com/v1";
const STOREFRONT_PAGE_SIZE = 100;
const PRODUCTS_PER_PAGE = 10;
const normalizeFourthwallDomain = (value: string | null | undefined) =>
  value?.replace(/^https?:\/\//, "").replace(/\/+$/, "") || "";
const isCustomDomain = (value: string | null | undefined) =>
  Boolean(value) && !value.endsWith(".fourthwall.com");
const configuredShopDomain = normalizeFourthwallDomain(
  import.meta.env.FOURTHWALL_SHOP_URL,
);

let products = [];
let error = null;
let checkoutDomain = configuredShopDomain;

const sortProductsForDisplay = (items: any[]) =>
  [...items].sort((a, b) => {
    const aIsHoodie = a.name?.toLowerCase().includes("hoodie") ? 0 : 1;
    const bIsHoodie = b.name?.toLowerCase().includes("hoodie") ? 0 : 1;

    return aIsHoodie - bIsHoodie;
  });

const fetchAllCollectionProducts = async (slug: string) => {
  const allProducts = [];
  let page = 0;

  while (true) {
    const productsUrl = new URL(`${STOREFRONT_URL}/collections/${slug}/products`);
    productsUrl.searchParams.set("storefront_token", STOREFRONT_TOKEN);
    productsUrl.searchParams.set("page", page.toString());
    productsUrl.searchParams.set("pageSize", STOREFRONT_PAGE_SIZE.toString());

    const productsRes = await fetch(productsUrl);
    if (!productsRes.ok)
      throw new Error(`Failed to fetch products: ${productsRes.status}`);

    const productsData = await productsRes.json();
    const pageProducts = productsData.results || productsData;
    allProducts.push(...pageProducts);

    if (!productsData.paging?.hasNextPage || !Array.isArray(productsData.results)) {
      break;
    }

    page += 1;
  }

  return allProducts;
};

try {
  // 1. Get Collections to find a slug
  const collectionsRes = await fetch(
    `${STOREFRONT_URL}/collections?storefront_token=${STOREFRONT_TOKEN}`,
  );
  if (!collectionsRes.ok)
    throw new Error(`Failed to fetch collections: ${collectionsRes.status}`);

  const collectionsData = await collectionsRes.json();
  const collections = collectionsData.results || collectionsData; // Handle potential wrapper

  if (collections.length > 0) {
    const allCollection = collections.find((c: any) => c.slug === "all");
    const targetCollection = allCollection || collections[0];
    const slug = targetCollection.slug;

    products = sortProductsForDisplay(await fetchAllCollectionProducts(slug));
  } else {
    // If no collections, maybe try empty search? But logic implies collections exist.
    console.warn("No collections found.");
  }
} catch (e) {
  error = e.message;
  console.error("Storefront API Error:", e);
}

if (STOREFRONT_TOKEN) {
  try {
    const shopRes = await fetch(
      `${STOREFRONT_URL}/shop?storefront_token=${STOREFRONT_TOKEN}`,
    );

    if (shopRes.ok) {
      const shopData = await shopRes.json();
      const publicShopDomain = normalizeFourthwallDomain(
        shopData.publicDomain || shopData.domain,
      );

      if (publicShopDomain) {
        checkoutDomain =
          configuredShopDomain && isCustomDomain(configuredShopDomain)
            ? configuredShopDomain
            : publicShopDomain;
      }
    } else {
      console.warn(`Failed to fetch shop details: ${shopRes.status}`);
    }
  } catch (e) {
    console.warn("Storefront shop details error:", e);
  }
}

// Fallback/Mock data if dev environment and API fails (optional, good for UI dev)
if (!products.length && import.meta.env.DEV && error) {
  products = sortProductsForDisplay([
    {
      id: "1",
      name: "Cool T-Shirt",
      images: [{ url: "https://placehold.co/400" }],
      variants: [
        {
          id: "var_1",
          unitPrice: { value: 25.0, currency: "USD" },
          name: "Default",
        },
      ],
    },
    {
      id: "2",
      name: "Awesome Hoodie",
      images: [{ url: "https://placehold.co/400" }],
      variants: [
        {
          id: "var_2",
          unitPrice: { value: 50.0, currency: "USD" },
          name: "Default",
        },
      ],
    },
  ]);
}

const { cta, title, subTitle } = metadata.merchPage;
const pageTitle = "Shop One More Moment | Support Adult Cancer Wishes";
const pageDescription =
  "Shop One More Moment merchandise and support meaningful wish experiences for adults facing late-stage cancer.";
const initialProducts = products.slice(0, PRODUCTS_PER_PAGE);
const initialVisibleCount = Math.min(PRODUCTS_PER_PAGE, products.length);
const initialTotalPages = Math.max(1, Math.ceil(products.length / PRODUCTS_PER_PAGE));
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="container mx-auto px-4 py-12">
    <div class="mb-16 text-center">
      <h1 class="mb-6 font-serif text-5xl text-[#2B2B40] md:text-6xl">
        {title}
      </h1>
      <p class="mx-auto max-w-2xl text-lg opacity-80">
        {subTitle}
      </p>
    </div>

    {
      error && !products.length ? (
        <div role="alert" class="alert alert-error mb-8">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 shrink-0 stroke-current"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span>
            Error loading products: {error}. Please check configuration.
          </span>
        </div>
      ) : null
    }

    <div
      id="products-grid"
      class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        initialProducts.map((product) => {
          // Find price range or starting price
          const firstVar = product.variants?.[0];
          const minPrice = firstVar?.unitPrice;

          return (
            <FadeIn>
              <div class="card bg-base-100 shadow-md transition-shadow duration-300 hover:shadow-xl">
                <figure class="px-3 pt-3">
                  {product.images?.[0]?.url ? (
                    <img
                      src={product.images[0].url}
                      alt={product.name}
                      class="h-48 w-full rounded-lg object-cover"
                    />
                  ) : (
                    <div class="flex h-48 w-full items-center justify-center rounded-lg bg-gray-200 text-gray-500">
                      No Image
                    </div>
                  )}
                </figure>
                <div class="card-body items-center p-4 text-center">
                  <h2 class="card-title text-base leading-tight">
                    {product.name}
                  </h2>
                  <p class="text-base font-semibold">
                    {minPrice
                      ? `From $${minPrice.value} ${minPrice.currency}`
                      : "Price unavailable"}
                  </p>
                  <div class="card-actions mt-2">
                    <button
                      class="btn btn-sm open-product-modal rounded-md bg-[#D9776E] text-white hover:bg-[#c5665d]"
                      data-id={product.id}
                    >
                      {cta}
                    </button>
                  </div>
                </div>
              </div>
            </FadeIn>
          );
        })
      }
    </div>

    <div
      id="products-pagination-shell"
      class:list={[
        "mt-10 flex flex-col items-center gap-4",
        initialTotalPages > 1 ? "" : "hidden",
      ]}
    >
      <p
        id="products-pagination-status"
        class="text-sm font-medium tracking-wide text-[#2B2B40]/75"
        aria-live="polite"
      >
        {
          products.length
            ? `Showing 1-${initialVisibleCount} of ${products.length} products`
            : "No products available"
        }
      </p>
      <div
        id="products-pagination"
        class="flex flex-wrap items-center justify-center gap-2"
      >
      </div>
    </div>
  </main>

  <!-- Product Modal -->
  <dialog id="product_modal" class="modal" slot="overlay">
    <div class="modal-box bg-base-100 w-11/12 max-w-4xl overflow-hidden p-0">
      <div class="flex h-full max-h-[85vh] flex-col md:flex-row">
        <!-- Image Section -->
        <div
          class="bg-base-200 flex w-full items-center justify-center p-6 md:w-1/2"
        >
          <img
            id="modal-image"
            src=""
            alt="Product"
            class="max-h-[50vh] rounded-lg object-contain shadow-sm"
          />
        </div>

        <!-- Details Section -->
        <div class="flex w-full flex-col overflow-y-auto p-8 md:w-1/2">
          <button
            class="btn btn-sm btn-circle btn-ghost absolute top-4 right-4 z-10"
            onclick="product_modal.close()">✕</button
          >

          <h3 class="mb-2 text-3xl font-bold" id="modal-title">Product Name</h3>
          <p
            class="mb-6 text-2xl font-semibold text-[#d9776e]"
            id="modal-price"
          >
            $0.00
          </p>

          <div id="modal-options" class="flex-1 space-y-6">
            <!-- Dynamic Options Injected Here -->
          </div>

          <div class="divider"></div>

          <div class="form-control mb-6 w-full max-w-xs">
            <label class="label"
              ><span class="label-text font-bold">Quantity</span></label
            >
            <div class="flex items-center">
              <button
                class="btn btn-square btn-outline btn-sm"
                onclick="window.updateModalQty(-1)">-</button
              >
              <input
                type="number"
                id="modal-qty"
                value="1"
                class="input input-bordered input-sm mx-2 w-20 text-center"
                min="1"
                readonly
              />
              <button
                class="btn btn-square btn-outline btn-sm"
                onclick="window.updateModalQty(1)">+</button
              >
            </div>
          </div>

          <button
            class="btn btn-block btn-lg rounded-md bg-[#D9776E] text-white hover:bg-[#c5665d]"
            id="modal-add-btn"
            disabled>Add to Cart</button
          >
        </div>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <script
    is:inline
    define:vars={{
      STOREFRONT_TOKEN,
      SHOP_DOMAIN: checkoutDomain,
      PRODUCTS_PER_PAGE,
      PRODUCTS: products,
      CTA: cta,
    }}
  >
    window.OMM_STOREFRONT_TOKEN = STOREFRONT_TOKEN;
    window.OMM_SHOP_DOMAIN = SHOP_DOMAIN;
    window.OMM_SHOP_URL = SHOP_DOMAIN;
    window.OMM_PRODUCTS_PER_PAGE = PRODUCTS_PER_PAGE;
    window.OMM_PRODUCTS = PRODUCTS;
    window.OMM_MERCH_CTA = CTA;
  </script>

  <script is:inline>
    (() => {
      const storefrontBaseUrl = "https://storefront-api.fourthwall.com/v1";
      const storefrontPageSize = 100;
      const productsPerPage = window.OMM_PRODUCTS_PER_PAGE || 10;
      const grid = document.getElementById("products-grid");
      const paginationShell = document.getElementById(
        "products-pagination-shell",
      );
      const paginationStatus = document.getElementById(
        "products-pagination-status",
      );
      const pagination = document.getElementById("products-pagination");
      let merchProducts = Array.isArray(window.OMM_PRODUCTS)
        ? window.OMM_PRODUCTS
        : [];
      let currentPage = 1;

      const sortProductsForDisplay = (items) =>
        [...items].sort((a, b) => {
          const aIsHoodie = a.name?.toLowerCase().includes("hoodie") ? 0 : 1;
          const bIsHoodie = b.name?.toLowerCase().includes("hoodie") ? 0 : 1;

          return aIsHoodie - bIsHoodie;
        });

      const formatPrice = (price) => {
        if (!price) return "Price unavailable";
        return `From $${price.value} ${price.currency}`;
      };

      const createProductCard = (product) => {
        const wrapper = document.createElement("div");
        wrapper.className = "animate-fade-in-up";

        const card = document.createElement("div");
        card.className =
          "card bg-base-100 shadow-md transition-shadow duration-300 hover:shadow-xl";

        const figure = document.createElement("figure");
        figure.className = "px-3 pt-3";

        const imageUrl = product.images?.[0]?.url;
        if (imageUrl) {
          const image = document.createElement("img");
          image.src = imageUrl;
          image.alt = product.name;
          image.className = "h-48 w-full rounded-lg object-cover";
          figure.appendChild(image);
        } else {
          const emptyImage = document.createElement("div");
          emptyImage.className =
            "flex h-48 w-full items-center justify-center rounded-lg bg-gray-200 text-gray-500";
          emptyImage.textContent = "No Image";
          figure.appendChild(emptyImage);
        }

        const body = document.createElement("div");
        body.className = "card-body items-center p-4 text-center";

        const title = document.createElement("h2");
        title.className = "card-title text-base leading-tight";
        title.textContent = product.name;

        const price = document.createElement("p");
        price.className = "text-base font-semibold";
        price.textContent = formatPrice(product.variants?.[0]?.unitPrice);

        const actions = document.createElement("div");
        actions.className = "card-actions mt-2";

        const button = document.createElement("button");
        button.className =
          "btn btn-sm open-product-modal rounded-md bg-[#D9776E] text-white hover:bg-[#c5665d]";
        button.dataset.id = product.id;
        button.textContent = window.OMM_MERCH_CTA || "Buy Now";

        actions.appendChild(button);
        body.append(title, price, actions);
        card.append(figure, body);
        wrapper.appendChild(card);

        return wrapper;
      };

      const getTotalPages = (items) =>
        Math.max(1, Math.ceil(items.length / productsPerPage));

      const getRequestedPage = () => {
        const page = Number.parseInt(
          new URL(window.location.href).searchParams.get("page") || "1",
          10,
        );

        return Number.isFinite(page) && page > 0 ? page : 1;
      };

      const syncPageInUrl = (page) => {
        const url = new URL(window.location.href);
        if (page <= 1) {
          url.searchParams.delete("page");
        } else {
          url.searchParams.set("page", page.toString());
        }

        window.history.replaceState({}, "", url);
      };

      const updatePaginationStatus = () => {
        if (!paginationStatus) return;

        if (!merchProducts.length) {
          paginationStatus.textContent = "No products available";
          return;
        }

        const start = (currentPage - 1) * productsPerPage + 1;
        const end = Math.min(start + productsPerPage - 1, merchProducts.length);
        paginationStatus.textContent =
          `Showing ${start}-${end} of ${merchProducts.length} products`;
      };

      const createPaginationButton = ({
        label,
        page,
        disabled = false,
        active = false,
      }) => {
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = label;
        button.disabled = disabled;
        button.className = active
          ? "btn btn-sm border-[#D9776E] bg-[#D9776E] text-white hover:border-[#c5665d] hover:bg-[#c5665d]"
          : "btn btn-sm btn-outline border-[#D9776E]/35 text-[#2B2B40] hover:border-[#D9776E] hover:bg-[#D9776E] hover:text-white";

        if (active) {
          button.setAttribute("aria-current", "page");
        }

        if (!disabled) {
          button.addEventListener("click", () => {
            setPage(page, { updateUrl: true, scroll: true });
          });
        }

        return button;
      };

      const renderPaginationControls = () => {
        if (!pagination || !paginationShell) return;

        pagination.replaceChildren();

        if (merchProducts.length <= productsPerPage) {
          paginationShell.classList.add("hidden");
          updatePaginationStatus();
          return;
        }

        paginationShell.classList.remove("hidden");
        const totalPages = getTotalPages(merchProducts);

        pagination.appendChild(
          createPaginationButton({
            label: "Previous",
            page: currentPage - 1,
            disabled: currentPage === 1,
          }),
        );

        for (let page = 1; page <= totalPages; page += 1) {
          pagination.appendChild(
            createPaginationButton({
              label: page.toString(),
              page,
              active: page === currentPage,
            }),
          );
        }

        pagination.appendChild(
          createPaginationButton({
            label: "Next",
            page: currentPage + 1,
            disabled: currentPage === totalPages,
          }),
        );

        updatePaginationStatus();
      };

      const renderCurrentPage = () => {
        if (!grid) return;

        const startIndex = (currentPage - 1) * productsPerPage;
        const visibleProducts = merchProducts.slice(
          startIndex,
          startIndex + productsPerPage,
        );

        grid.replaceChildren(...visibleProducts.map(createProductCard));
        renderPaginationControls();
      };

      const setPage = (
        page,
        { updateUrl = false, scroll = false } = {},
      ) => {
        currentPage = Math.min(Math.max(page, 1), getTotalPages(merchProducts));
        renderCurrentPage();

        if (updateUrl) {
          syncPageInUrl(currentPage);
        }

        if (scroll && grid) {
          grid.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      };

      const applyProducts = (items, { useRequestedPage = false } = {}) => {
        merchProducts = sortProductsForDisplay(items);
        window.OMM_PRODUCTS = merchProducts;
        currentPage = Math.min(
          useRequestedPage ? getRequestedPage() : currentPage,
          getTotalPages(merchProducts),
        );

        renderCurrentPage();
        syncPageInUrl(currentPage);
      };

      const fetchAllCollectionProducts = async (collectionSlug, token) => {
        const allProducts = [];
        let page = 0;

        while (true) {
          const productsUrl = new URL(
            `${storefrontBaseUrl}/collections/${collectionSlug}/products`,
          );
          productsUrl.searchParams.set("storefront_token", token);
          productsUrl.searchParams.set("page", page.toString());
          productsUrl.searchParams.set("pageSize", storefrontPageSize.toString());

          const productsRes = await fetch(productsUrl, { cache: "no-store" });
          if (!productsRes.ok) {
            throw new Error(`Products request failed: ${productsRes.status}`);
          }

          const productsData = await productsRes.json();
          const pageProducts = productsData.results || productsData;
          allProducts.push(...pageProducts);

          if (
            !productsData.paging?.hasNextPage ||
            !Array.isArray(productsData.results)
          ) {
            break;
          }

          page += 1;
        }

        return allProducts;
      };

      async function refreshFourthwallProducts() {
        const token = window.OMM_STOREFRONT_TOKEN;
        if (!token || !grid) return;

        try {
          const collectionsRes = await fetch(
            `${storefrontBaseUrl}/collections?storefront_token=${token}`,
            { cache: "no-store" },
          );
          if (!collectionsRes.ok) return;

          const collectionsData = await collectionsRes.json();
          const collections = collectionsData.results || collectionsData;
          const allCollection = collections.find(
            (collection) => collection.slug === "all",
          );
          const targetCollection = allCollection || collections[0];
          if (!targetCollection?.slug) return;

          const latestProducts = sortProductsForDisplay(
            await fetchAllCollectionProducts(targetCollection.slug, token),
          );
          if (!Array.isArray(latestProducts) || !latestProducts.length) return;

          applyProducts(latestProducts);
        } catch (error) {
          console.error("Unable to refresh Fourthwall products:", error);
        }
      }

      applyProducts(merchProducts, { useRequestedPage: true });
      refreshFourthwallProducts();
    })();
  </script>

  <script src="/js/product-modal.js" is:inline></script>
  <!-- Shopping Cart UI (Drawer/Modal) -->
  <div slot="overlay" id="cart-drawer" class="fixed inset-0 z-[999] hidden">
    <div
      class="absolute inset-0 bg-black/50 backdrop-blur-sm"
      id="cart-overlay"
    >
    </div>
    <div
      class="bg-base-100 absolute top-0 right-0 flex h-full w-full max-w-md translate-x-full transform flex-col p-6 shadow-2xl transition-transform"
      id="cart-content"
    >
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-2xl font-bold">Your Cart</h2>
        <button class="btn btn-circle btn-ghost" id="close-cart">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path></svg
          >
        </button>
      </div>

      <div id="cart-items" class="flex-1 space-y-4 overflow-y-auto">
        <!-- Cart items injected here -->
        <p class="mt-10 text-center text-gray-500">Your cart is empty.</p>
      </div>

      <div class="mt-4 border-t pt-4">
        <div class="mb-4 flex justify-between text-xl font-bold">
          <span>Total</span>
          <span id="cart-total">$0.00</span>
        </div>
        <button
          class="btn btn-block bg-[#D9776E] text-white hover:bg-[#c5665d]"
          id="checkout-btn">Checkout</button
        >
      </div>
    </div>
  </div>

  <!-- Floating Cart Button -->
  <button
    slot="overlay"
    id="open-cart-btn"
    class="btn btn-primary btn-circle btn-lg fixed right-8 bottom-8 z-40 shadow-lg transition-all duration-300 hover:scale-105"
  >
    <div class="indicator">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
        ></path></svg
      >
      <span class="indicator-item badge badge-secondary" id="cart-count">0</span
      >
    </div>
  </button>

  <script src="/js/cart.js" is:inline></script>
</Layout>

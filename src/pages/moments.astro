---
import Base from "../layouts/Base.astro";
import { frontmatter as metadata } from "../data/metadata.mdx";
import { XMLParser } from "fast-xml-parser";

const RSS_URL =
  "https://www.youtube.com/feeds/videos.xml?channel_id=UCNiuY3dRukTTWzjSHvESbFA";

interface Video {
  id: string;
  title: string;
  link: string;
  published: string;
  thumbnail: string;
}

const makePoster = (title: string, label: string) =>
  `data:image/svg+xml,${encodeURIComponent(`
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 720">
      <defs>
        <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#2B2B40"/>
          <stop offset="1" stop-color="#D9776E"/>
        </linearGradient>
        <radialGradient id="light" cx="70%" cy="22%" r="65%">
          <stop offset="0" stop-color="#F7EFE8" stop-opacity=".18"/>
          <stop offset=".52" stop-color="#F7EFE8" stop-opacity=".06"/>
          <stop offset="1" stop-color="#F7EFE8" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <rect width="1280" height="720" fill="url(#bg)"/>
      <rect width="1280" height="720" fill="url(#light)"/>
      <rect x="86" y="86" width="1108" height="548" rx="24" fill="none" stroke="#FAF7F1" stroke-width="3"/>
      <rect x="122" y="124" width="110" height="6" fill="#D9776E"/>
      <text x="122" y="202" fill="#EEE0D7" font-family="Arial, sans-serif" font-size="28" font-weight="700" letter-spacing="2">${label.toUpperCase()}</text>
      <text x="122" y="330" fill="#FAF7F1" font-family="Georgia, serif" font-size="78" font-weight="700">${title}</text>
      <text x="122" y="566" fill="#EEE0D7" font-family="Arial, sans-serif" font-size="34">Watch the video</text>
      <circle cx="1105" cy="550" r="48" fill="#FAF7F1"/>
      <path d="M1090 522v56l44-28z" fill="#2B2B40"/>
    </svg>
  `)}`;

const localMoments = [
  {
    title: "Russlan's Moment",
    videoSrc: "/blog/Nicholas%20Family_Disney.mp4",
    posterSrc: makePoster("Russlan's Moment", "One More Moment"),
  },
  {
    title: "Josh's Moment",
    videoSrc: "/blog/josh-moment.mp4",
    posterSrc: makePoster("Josh's Moment", "One More Moment"),
  },
  {
    title: "Clyde's Moment",
    videoSrc: "/blog/clyde-moment.mp4",
    posterSrc: makePoster("Clyde's Moment", "One More Moment"),
  },
  {
    title: "Bruce's Moment",
    videoSrc: "/blog/bruce-reynolds-first-one-more-moment.mp4",
    posterSrc: makePoster("Bruce's Moment", "One More Moment"),
  },
];

const localEventVideos = [
  {
    title: "Whitecaps Raffle",
    videoSrc: "/blog/Whitecaps%20Raffle%201.mp4",
    posterSrc: makePoster("Whitecaps Raffle", "Community Event"),
  },
];

const communityEventVideos: Video[] = [
  {
    id: "Xp35_5XtgJg",
    title: "Polo Fields Golf Outing Video",
    link: "https://www.youtube.com/watch?v=Xp35_5XtgJg",
    published: "YouTube",
    thumbnail: "https://i.ytimg.com/vi/Xp35_5XtgJg/maxresdefault.jpg",
  },
];

const communityEventVideoIds = new Set(
  communityEventVideos.map((video) => video.id),
);

const youtubeTitleExclusions = ["bruce", "clyde", "josh", "joshua clark"];

const fallbackVideos: Video[] = [
  {
    id: "1O0sKmzn4js",
    title: "Dennis's Moment",
    link: "https://www.youtube.com/watch?v=1O0sKmzn4js",
    published: "YouTube",
    thumbnail: "https://i.ytimg.com/vi/1O0sKmzn4js/maxresdefault.jpg",
  },
  {
    id: "8r_UTgD-_5Q",
    title: "Tim's Moment",
    link: "https://www.youtube.com/watch?v=8r_UTgD-_5Q",
    published: "YouTube",
    thumbnail: "https://i.ytimg.com/vi/8r_UTgD-_5Q/maxresdefault.jpg",
  },
  {
    id: "BP8g7k7Y28E",
    title: "One More Moment Wish Granting",
    link: "https://www.youtube.com/watch?v=BP8g7k7Y28E",
    published: "YouTube",
    thumbnail: "https://i.ytimg.com/vi/BP8g7k7Y28E/maxresdefault.jpg",
  },
];

let videos: Video[] = [];

try {
  const response = await fetch(RSS_URL);
  if (!response.ok) {
    throw new Error(`Failed to fetch RSS feed: ${response.statusText}`);
  }
  const xmlText = await response.text();
  const parser = new XMLParser({
    ignoreAttributes: false,
    attributeNamePrefix: "@_",
  });
  const parsed = parser.parse(xmlText);
  const entries = parsed.feed.entry || [];

  videos = entries
    .map((entry: any): Video => ({
      id: entry["yt:videoId"],
      title: entry.title,
      link: entry.link["@_href"],
      published: new Date(entry.published).toLocaleDateString(),
      thumbnail: `https://i.ytimg.com/vi/${entry["yt:videoId"]}/maxresdefault.jpg`,
    }))
    .filter((video: Video) => {
      const title = video.title.toLowerCase();
      return (
        !communityEventVideoIds.has(video.id) &&
        !youtubeTitleExclusions.some((excludedTitle) =>
          title.includes(excludedTitle),
        )
      );
    });
} catch (e) {
  console.error("Error fetching YouTube feed:", e);
}

if (videos.length === 0) {
  videos = fallbackVideos;
}

const { title, subTitle } = metadata.momentsPage;
const pageTitle = "Request a Moment | One More Moment";
const pageDescription =
  "Watch One More Moment stories and learn how adults in Michigan facing Stage IV, advanced, or metastatic cancer can request a meaningful Moment.";
---

<Base title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-12">
    <div class="mb-12 text-center">
      <h1 class="mb-6 font-serif text-5xl text-[#2B2B40] md:text-6xl">
        {title}
      </h1>
      <p class="text-base-content/70 text-lg">
        {subTitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        localMoments.map((moment) => (
          <article class="card bg-base-100 shadow-xl">
            <figure class="relative aspect-video overflow-hidden bg-black">
              <video
                src={moment.videoSrc}
                poster={moment.posterSrc}
                class="h-full w-full object-cover"
                controls
                preload="metadata"
                playsinline
              >
                Your browser does not support the video tag.
              </video>
            </figure>
            <div class="card-body">
              <h2 class="card-title line-clamp-2 text-lg leading-snug">
                {moment.title}
              </h2>
              <div class="card-actions mt-4 justify-end">
                <div class="badge rounded-md bg-[#D9776E] text-white">
                  Moment
                </div>
              </div>
            </div>
          </article>
        ))
      }

      {
        videos.map((video) => (
          <a
            href={video.link}
            target="_blank"
            rel="noopener noreferrer"
            class="card bg-base-100 shadow-xl transition-transform duration-300 hover:scale-105 hover:shadow-2xl"
          >
            <figure class="relative aspect-video overflow-hidden">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 transition-opacity duration-300 hover:opacity-100">
                <svg
                  class="h-16 w-16 text-white drop-shadow-lg"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </figure>
            <div class="card-body">
              <h2 class="card-title line-clamp-2 text-lg leading-snug">
                {video.title}
              </h2>
              <div class="card-actions mt-4 justify-end">
                <span class="text-base-content/60 mr-auto self-center font-mono text-xs">
                  {video.published}
                </span>
                <div class="badge rounded-md bg-[#D9776E] text-white hover:bg-[#c5665d]">
                  Watch
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <section class="mt-16">
      <div class="mb-8 text-center">
        <h2 class="mb-3 font-serif text-4xl text-[#2B2B40]">
          Community Events
        </h2>
        <p class="text-base-content/70 text-lg">
          Fun moments from the events and fundraisers that help make this work
          possible.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          localEventVideos.map((event) => (
            <article class="card bg-base-100 shadow-xl">
              <figure class="relative aspect-video overflow-hidden bg-black">
                <video
                  src={event.videoSrc}
                  poster={event.posterSrc}
                  class="h-full w-full object-cover"
                  controls
                  preload="metadata"
                  playsinline
                >
                  Your browser does not support the video tag.
                </video>
              </figure>
              <div class="card-body">
                <h2 class="card-title line-clamp-2 text-lg leading-snug">
                  {event.title}
                </h2>
                <div class="card-actions mt-4 justify-end">
                  <div class="badge rounded-md bg-[#2B2B40] text-white">
                    Fundraiser
                  </div>
                </div>
              </div>
            </article>
          ))
        }

        {
          communityEventVideos.map((video) => (
            <a
              href={video.link}
              target="_blank"
              rel="noopener noreferrer"
              class="card bg-base-100 shadow-xl transition-transform duration-300 hover:scale-105 hover:shadow-2xl"
            >
              <figure class="relative aspect-video overflow-hidden">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 transition-opacity duration-300 hover:opacity-100">
                  <svg
                    class="h-16 w-16 text-white drop-shadow-lg"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </figure>
              <div class="card-body">
                <h2 class="card-title line-clamp-2 text-lg leading-snug">
                  {video.title}
                </h2>
                <div class="card-actions mt-4 justify-end">
                  <span class="text-base-content/60 mr-auto self-center font-mono text-xs">
                    {video.published}
                  </span>
                  <div class="badge rounded-md bg-[#2B2B40] text-white">
                    Fundraiser
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    {/* Moment Request Form */}
    <section id="request-a-moment" class="mx-auto mt-24 max-w-2xl">
      <div class="mb-10 text-center">
        <h2 class="mb-4 font-serif text-4xl text-[#2B2B40]">
          Request a Moment
        </h2>
        <p class="text-lg opacity-80">
          Know someone who needs a special moment? Let us know.
        </p>
      </div>

      <form id="moment-request-form" class="flex flex-col gap-6">
        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Your name</span>
          </label>
          <input
            type="text"
            name="requesterName"
            placeholder="Name of the person submitting this request"
            class="input input-bordered text-red w-full rounded-md text-gray-400 focus:outline-offset-0"
            required
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Your email</span>
          </label>
          <input
            type="email"
            name="requesterEmail"
            placeholder="Email for the person submitting this request"
            class="input input-bordered w-full rounded-md text-gray-400 focus:outline-offset-0"
            required
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Your phone</span>
          </label>
          <input
            type="tel"
            name="requesterPhone"
            placeholder="Phone number for the person submitting this request"
            class="input input-bordered w-full rounded-md text-gray-400 focus:outline-offset-0"
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Name of the person this Moment is for</span>
          </label>
          <input
            type="text"
            name="warriorName"
            placeholder="Name of the person facing cancer"
            class="input input-bordered w-full rounded-md text-gray-400 focus:outline-offset-0"
            required
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Your relationship to them</span>
          </label>
          <input
            type="text"
            name="relationshipToWarrior"
            placeholder="For example: spouse, child, friend, caregiver"
            class="input input-bordered w-full rounded-md text-gray-400 focus:outline-offset-0"
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">How did you hear about us?</span>
          </label>
          <input
            type="text"
            name="howDidYouHearAboutUs"
            placeholder="For example: social media, Google, a friend, hospital, hospice, or care team"
            class="input input-bordered w-full rounded-md text-gray-400 focus:outline-offset-0"
          />
        </div>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text">Tell us about the person and the Moment being requested</span>
          </label>
          <textarea
            name="situation"
            class="textarea textarea-bordered h-32 w-full rounded-md text-gray-400 focus:outline-offset-0"
            placeholder="Share who the Moment is for, what they are facing, and what would be meaningful to them"
            required></textarea>
        </div>

        <div class="mt-4 text-center">
          <button
            type="submit"
            class="btn min-w-[200px] rounded-md bg-[#D9776E] px-8 text-white hover:bg-[#c5665d]"
          >
            Submit Request
          </button>
        </div>
      </form>
    </section>
  </div>
</Base>

<script>
  const form = document.getElementById(
    "moment-request-form",
  ) as HTMLFormElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    if (!submitBtn) return;

    const originalText = submitBtn.innerText;
    submitBtn.innerText = "Submitting...";
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.name = data.requesterName;
    data.email = data.requesterEmail;
    data.phone = data.requesterPhone;

    try {
      const response = await fetch("/api/submit-moment", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        console.info("[analytics] moment_request_submit");

        if (typeof window.gtag === "function") {
          window.gtag("event", "moment_request_submit", {
            form_name: "moment_request",
            page_path: window.location.pathname,
          });
        }

        alert("Thank you for your request! We will be in touch soon.");
        form.reset();
      } else {
        alert(
          result.message || "Something went wrong. Please try again later.",
        );
      }
    } catch (error) {
      console.error("Error:", error);
      alert("An error occurred. Please try again.");
    } finally {
      submitBtn.innerText = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

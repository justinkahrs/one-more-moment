---
import Base from "../layouts/Base.astro";
import FadeIn from "../components/FadeIn.astro";
import { Image } from "astro:assets";
import { frontmatter as metadata } from "../data/metadata.mdx";

import aboutPageImg from "../assets/about-page.jpg";
import jasonImg from "../assets/Jason-Pohlonski-Headshot-1024x683.jpg";
import simoneImg from "../assets/Simone-Goga-Headshot.jpeg";
import carrieImg from "../assets/Carrie-House-Headshot-1024x683.jpg";
import andyImg from "../assets/Andy-Thompson-Headshot-1024x683.jpg";
import dianeImg from "../assets/ChatGPT Image May 8, 2026, 10_08_46 PM.jpg";

const teamImages = {
  jasonImg,
  simoneImg,
  carrieImg,
  andyImg,
  dianeImg,
};

type TeamImageKey = keyof typeof teamImages;

interface TeamMember {
  name: string;
  image: TeamImageKey;
  bio: string;
  alt?: string;
}

interface AboutData {
  title: string;
  mission: {
    title: string;
    content: string;
  };
  story: {
    title: string;
    intro: string;
    quote: string;
    outro: string;
  };
  whatWeDo: {
    title: string;
    content: string;
  };
  team: {
    title: string;
    video: string;
    members: TeamMember[];
  };
}

const { about } = metadata as { about: AboutData };
const { mission, story, whatWeDo, team } = about;
const pageTitle = "Our Mission | One More Moment";
const pageDescription =
  "Learn about One More Moment's mission, founding story, and team helping adults with late-stage cancer create meaningful Moments with loved ones.";
const splitParagraphs = (content: string) => content.split("\n\n");
---

<Base title={pageTitle} description={pageDescription}>
  <div class="prose-h1:font-normal flex justify-center p-12">
    <article class="prose md:prose-lg max-w-6xl">
      <h1
        class="mb-6 text-center font-serif text-5xl text-[#2B2B40] md:text-6xl"
      >
        {about.title}
      </h1>

      {/* Mission Section */}
      <div class="grid items-center gap-8 md:grid-cols-2">
        <div>
          <h2>{mission.title}</h2>
          <p>{mission.content}</p>
        </div>
        <div>
          <Image
            src={aboutPageImg}
            alt="Woman sits with child in the grass in front of a fence"
            class="rounded-lg"
          />
        </div>
      </div>

      {/* Story Section */}
      <h2>{story.title}</h2>

      {splitParagraphs(story.intro).map((paragraph) => <p>{paragraph}</p>)}

      <blockquote>{story.quote}</blockquote>

      {splitParagraphs(story.outro).map((paragraph) => <p>{paragraph}</p>)}

      {/* What We Do Section */}
      <h2>{whatWeDo.title}</h2>

      {splitParagraphs(whatWeDo.content).map((paragraph) => <p>{paragraph}</p>)}

      <iframe
        class="aspect-video w-full"
        src={team.video}
        title="YouTube Video Player"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"></iframe>
      {/* Team Section */}
      <h2>{team.title}</h2>

      <div class="mt-12 space-y-12">
        {
          team.members.map((member, index) => (
            <FadeIn>
              <div class="grid items-center gap-8 md:grid-cols-2">
                <div class={index % 2 !== 0 ? "order-2 md:order-1" : ""}>
                  {index % 2 !== 0 ? (
                    <>
                      <h3>{member.name}</h3>
                      {splitParagraphs(member.bio).map((paragraph) => (
                        <p>{paragraph}</p>
                      ))}
                    </>
                  ) : (
                    <Image
                      src={teamImages[member.image]}
                      alt={member.alt || member.name}
                      class="rounded-lg"
                    />
                  )}
                </div>
                <div class={index % 2 !== 0 ? "order-1 md:order-2" : ""}>
                  {index % 2 !== 0 ? (
                    <Image
                      src={teamImages[member.image]}
                      alt={member.alt || member.name}
                      class="rounded-lg"
                    />
                  ) : (
                    <>
                      <h3>{member.name}</h3>
                      {splitParagraphs(member.bio).map((paragraph) => (
                        <p>{paragraph}</p>
                      ))}
                    </>
                  )}
                </div>
              </div>
            </FadeIn>
          ))
        }
      </div>
    </article>
  </div>
</Base>

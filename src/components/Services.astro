---
import { frontmatter as metadata } from "../data/metadata.mdx";
import { HeartHandshake, UsersRound, HandHeart } from "@lucide/astro";

const iconMap = {
  HeartHandshake,
  UsersRound,
  HandHeart,
};

type IconName = keyof typeof iconMap;

interface ServiceItem {
  title: string;
  description: string;
  icon?: IconName;
}

const servicesSection = metadata.servicesSection ?? {};
const title = servicesSection.title ?? "";
const services = (servicesSection.items ?? []) as ServiceItem[];
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-16 text-center text-3xl font-bold text-[#2B2B40] md:text-4xl">
      {title}
    </h2>

    <div class="grid gap-12 text-center md:grid-cols-3">
      {
        services.map((service) => {
          const Icon = service.icon ? iconMap[service.icon] : undefined;

          return (
            <div class="flex flex-col items-center transition-all duration-300 hover:scale-105">
              <>
                <div class="mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-[#E5DACE] text-[#D9776E]">
                  {Icon ? <Icon size={40} /> : <span class="text-4xl">★</span>}
                </div>
                <h3 class="mb-4 text-xl font-bold text-[#2B2B40]">
                  {service.title}
                </h3>
              </>

              <p class="max-w-xs leading-relaxed text-[#4A4A4A]">
                {service.description}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

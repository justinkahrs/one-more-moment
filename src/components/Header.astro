---
import { frontmatter as metadata } from "../data/metadata.mdx";
import clsx from "clsx";
import Logo from "../assets/omm-new-logo.png";
import LogoScrolled from "../assets/omm-horz-logo.png";

const HeaderData = metadata.header ?? {};
const companyName = metadata.name;
const { navItems = [], cta, sticky } = HeaderData;
const { overlay = false } = Astro.props;

interface NavItem {
  name: string;
  href: string;
  children?: NavItem[];
}
---

<style>
  .logo-container {
    display: inline-grid;
    grid-template-areas: "logo";
    align-items: center;
    justify-items: start;
  }

  /* Transition Properties */
  .logo-unscrolled,
  .logo-scrolled {
    grid-area: logo;
    width: auto;
    object-fit: contain;
    transition:
      opacity 0.5s ease-in-out,
      transform 0.5s ease-in-out,
      height 0.5s ease-in-out;
  }

  /* Desktop Default State (Large) */
  @media (min-width: 1024px) {
    #navbar-header:not(.scrolled) .logo-unscrolled {
      height: 12rem; /* h-48 */
      opacity: 1;
      transform: translateY(0);
    }
    #navbar-header:not(.scrolled) .logo-scrolled {
      height: 0;
      opacity: 0;
      pointer-events: none;
      transform: translateY(10px);
    }

    /* Desktop Scrolled State (Small) */
    #navbar-header.scrolled .logo-unscrolled {
      height: 0;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-10px);
    }
    #navbar-header.scrolled .logo-scrolled {
      height: 5rem; /* 80px */
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile Default State */
  @media (max-width: 1023px) {
    #navbar-header:not(.scrolled) .logo-unscrolled {
      height: 6rem; /* h-24 */
      opacity: 1;
    }
    #navbar-header:not(.scrolled) .logo-scrolled {
      height: 0;
      opacity: 0;
      pointer-events: none;
    }

    /* Mobile Scrolled State */
    #navbar-header.scrolled .logo-unscrolled {
      height: 0;
      opacity: 0;
      pointer-events: none;
    }
    #navbar-header.scrolled .logo-scrolled {
      height: 3rem; /* h-12 */
      opacity: 1;
    }
  }

  /* Desktop Header Padding Transition */
  @media (min-width: 1024px) {
    #navbar-header {
      padding-top: 1rem;
      padding-bottom: 1rem;
      transition: padding 0.5s ease-in-out;
    }
    #navbar-header.scrolled {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
  }
</style>

<script>
  function handleScroll() {
    const header = document.getElementById("navbar-header");
    if (window.scrollY > 150) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  }

  window.addEventListener("scroll", handleScroll);
  // Check once on load
  handleScroll();
</script>
<div
  id="navbar-header"
  class={clsx(
    "navbar z-100 shadow-lg backdrop-blur-md transition-all duration-500",
    overlay
      ? "fixed top-0 w-full bg-white border-b border-white/20"
      : "bg-base-100/90",
    !overlay && sticky && "sticky top-0",
  )}
>
  <div class="navbar-start">
    <div class="dropdown">
      <div
        tabindex="0"
        role="button"
        id="Menu"
        aria-label="Menu"
        class="btn btn-ghost lg:hidden"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h8m-8 6h16"></path>
        </svg>
      </div>
      <ul
        tabindex="0"
        class="menu menu-xl dropdown-content bg-base-100 rounded-box z-50 mt-3 w-52 p-2 shadow"
      >
        {
          navItems.map(({ children, href, name }: NavItem) =>
            children ? (
              <li>
                <details>
                  <summary>{name}</summary>
                  <ul class="p-2">
                    {children.map(({ href, name }: NavItem) => (
                      <li>
                        <a href={href}>{name}</a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a href={href}>{name}</a>
              </li>
            ),
          )
        }
      </ul>
    </div>
    <a href="/" class="logo-container text-xl font-bold lg:mx-4">
      <img
        src={Logo.src}
        alt={companyName}
        class="logo-unscrolled rounded-lg"
        loading="eager"
      />
      <img
        src={LogoScrolled.src}
        alt={companyName}
        class="logo-scrolled rounded-lg"
        loading="eager"
      />
    </a>
  </div>

  <div class="navbar-end hidden w-full lg:flex">
    <ul class="menu menu-horizontal px-1 text-lg font-semibold">
      {
        navItems.map((item: NavItem) =>
          item.children ? (
            <li>
              <details>
                <summary>{item.name}</summary>
                <ul class="p-2">
                  {item.children.map((child: NavItem) => (
                    <li>
                      <a href={child.href}>{child.name}</a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          ) : (
            <li>
              <a href={item.href}>{item.name}</a>
            </li>
          ),
        )
      }
    </ul>
    {
      cta && (
        <a
          class="btn btn-lg mx-4 mr-20 rounded-md border-0 bg-[#D9776E] px-6 text-white hover:bg-[#c5665d]"
          href={cta.href}
        >
          {cta.label}
        </a>
      )
    }
  </div>
</div>

---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { fade } from "astro:transitions";
import { frontmatter as meta } from "../data/metadata.mdx";

const {
  title,
  description: pageDescription,
  overlayHeader = false,
  image = meta.seo?.ogImage || "/og-image.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const seo = meta.seo || {};
const siteUrl = Astro.site || new URL("https://www.onemoremoment.org");

const pageTitle =
  title || seo.title || `${meta.name}${meta.primaryService ? ` | ${meta.primaryService}` : ""}`;

const description = pageDescription || seo.description || (meta.hero && meta.hero.content) || "";
const canonical = new URL(canonicalUrl || Astro.url.pathname, siteUrl).toString();
const socialImage = new URL(image, siteUrl).toString();

const keywords = [
  seo.cityKeyword,
  seo.serviceKeyword,
  meta.serviceCategory,
  meta.primaryService,
  meta.primaryAudience,
  meta.industryNiche,
  meta.regionsServed,
]
  .filter(Boolean)
  .join(", ");
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-9TXZJ8T4G1"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-9TXZJ8T4G1");
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={meta.name} />
    <meta name="msvalidate.01" content="D5B4BA51F2F2AC205901468B0C2EB509" />
    {
      meta.location?.cityState && (
        <meta name="geo.placename" content={meta.location.cityState} />
      )
    }
    {
      meta.location?.state && (
        <meta name="geo.region" content={meta.location.state} />
      )
    }
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:site_name" content={meta.name} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <slot name="head" />
  </head>

  <body class="bg-base-100 text-base-content flex min-h-screen flex-col">
    <Header overlay={overlayHeader} />
    <main class="flex-1" transition:animate={fade({ duration: 250 })}>
      <slot />
    </main>
    <Footer />
    <slot name="overlay" />
  </body>
</html>
